generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// MULTIEMPRESA
// ==========================================

model Empresa {
  id            Int       @id @default(autoincrement())
  nombre        String
  nit           String    @unique
  email         String
  telefono      String?
  direccion     String?
  logo          String?
  activo        Boolean   @default(true)
  creadoEn      DateTime  @default(now())
  actualizadoEn DateTime  @updatedAt

  usuarios    Usuario[]
  sucursales  Sucursal[]
  categorias  Categoria[]
  productos   Producto[]
  clientes    Cliente[]
  movimientos MovimientoFinanciero[]

  @@map("empresas")
}

model Sucursal {
  id        Int      @id @default(autoincrement())
  empresaId Int
  nombre    String
  direccion String?
  telefono  String?
  activo    Boolean  @default(true)
  creadoEn  DateTime @default(now())

  empresa     Empresa                @relation(fields: [empresaId], references: [id])
  usuarios    Usuario[]
  pedidos     Pedido[]
  cajas       Caja[]
  movimientos MovimientoFinanciero[]

  @@map("sucursales")
}

// ==========================================
// USUARIOS Y ROLES
// ==========================================

enum RolUsuario {
  SUPERADMIN
  ADMIN_EMPRESA
  GERENTE
  CAJERO
  COCINERO
  DOMICILIARIO
}

model Usuario {
  id            Int        @id @default(autoincrement())
  empresaId     Int?
  sucursalId    Int?
  nombre        String
  email         String     @unique
  password      String
  rol           RolUsuario
  activo        Boolean    @default(true)
  creadoEn      DateTime   @default(now())
  actualizadoEn DateTime   @updatedAt

  empresa     Empresa?               @relation(fields: [empresaId], references: [id])
  sucursal    Sucursal?              @relation(fields: [sucursalId], references: [id])
  pedidos     Pedido[]
  cajas       Caja[]
  eventos     EventoCaja[]
  movimientos MovimientoFinanciero[]
  movimientosInventario MovimientoInventario[]

  @@map("usuarios")
}

// ==========================================
// PRODUCTOS Y CATEGORIAS
// ==========================================

model Categoria {
  id          Int      @id @default(autoincrement())
  empresaId   Int
  nombre      String
  descripcion String?
  icono       String?
  color       String?
  activo      Boolean  @default(true)
  creadoEn    DateTime @default(now())

  empresa   Empresa    @relation(fields: [empresaId], references: [id])
  productos Producto[]

  @@map("categorias")
}

model Producto {
  id            Int      @id @default(autoincrement())
  empresaId     Int
  categoriaId   Int
  nombre        String
  descripcion   String?
  precio        Decimal  @db.Decimal(10, 2)
  imagen        String?
  disponible    Boolean  @default(true)
  activo        Boolean  @default(true)
  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  empresa        Empresa               @relation(fields: [empresaId], references: [id])
  categoria      Categoria             @relation(fields: [categoriaId], references: [id])
  ingredientes   ProductoIngrediente[]
  detallesPedido DetallePedido[]

  @@map("productos")
}

model Ingrediente {
  id               Int      @id @default(autoincrement())
  nombre           String
  unidad           String
  unidadCompra     String?
  factorConversion Decimal? @db.Decimal(10, 3)
  stock            Decimal  @db.Decimal(10, 3)
  stockMinimo      Decimal  @db.Decimal(10, 3) @default(0)
  activo           Boolean  @default(true)
  creadoEn         DateTime @default(now())

  productos    ProductoIngrediente[]
  movimientos  MovimientoInventario[]

  @@map("ingredientes")
}
model MovimientoInventario {
  id              Int      @id @default(autoincrement())
  ingredienteId   Int
  usuarioId       Int
  tipo            String
  cantidadMovida  Decimal  @db.Decimal(10, 3)
  unidadCompra    String?
  factorAplicado  Decimal? @db.Decimal(10, 3)
  stockAnterior   Decimal  @db.Decimal(10, 3)
  stockNuevo      Decimal  @db.Decimal(10, 3)
  descripcion     String?
  creadoEn        DateTime @default(now())

  ingrediente Ingrediente @relation(fields: [ingredienteId], references: [id])
  usuario     Usuario     @relation(fields: [usuarioId], references: [id])

  @@map("movimientos_inventario")
}

model ProductoIngrediente {
  id            Int     @id @default(autoincrement())
  productoId    Int
  ingredienteId Int
  cantidad      Decimal @db.Decimal(10, 3)

  producto    Producto    @relation(fields: [productoId], references: [id])
  ingrediente Ingrediente @relation(fields: [ingredienteId], references: [id])

  @@unique([productoId, ingredienteId])
  @@map("producto_ingredientes")
}

// ==========================================
// POS - PEDIDOS Y VENTAS
// ==========================================

enum EstadoPedido {
  PENDIENTE
  EN_COCINA
  LISTO
  ENTREGADO
  ANULADO
}

enum MetodoPago {
  EFECTIVO
  TARJETA
  TRANSFERENCIA
  NEQUI
  DAVIPLATA
}

model Cliente {
  id              Int       @id @default(autoincrement())
  empresaId       Int
  nombre          String
  documento       String?
  telefono        String?
  email           String?
  direccion       String?
  fechaNacimiento DateTime?
  puntos          Int       @default(0)
  activo          Boolean   @default(true)
  creadoEn        DateTime  @default(now())

  empresa Empresa  @relation(fields: [empresaId], references: [id])
  pedidos Pedido[]

  @@unique([empresaId, documento])
  @@map("clientes")
}

model Pedido {
  id            Int          @id @default(autoincrement())
  sucursalId    Int
  usuarioId     Int
  clienteId     Int?
  cajaId        Int?
  numero        String       @unique
  estado        EstadoPedido @default(PENDIENTE)
  metodoPago    MetodoPago   @default(EFECTIVO)
  subtotal      Decimal      @db.Decimal(10, 2)
  descuento     Decimal      @db.Decimal(10, 2) @default(0)
  total         Decimal      @db.Decimal(10, 2)
  observacion   String?
  creadoEn      DateTime     @default(now())
  actualizadoEn DateTime     @updatedAt

  sucursal    Sucursal               @relation(fields: [sucursalId], references: [id])
  usuario     Usuario                @relation(fields: [usuarioId], references: [id])
  cliente     Cliente?               @relation(fields: [clienteId], references: [id])
  caja        Caja?                  @relation(fields: [cajaId], references: [id])
  detalles    DetallePedido[]
  movimientos MovimientoFinanciero[]

  @@map("pedidos")
}

model DetallePedido {
  id             Int     @id @default(autoincrement())
  pedidoId       Int
  productoId     Int
  cantidad       Int
  precioUnitario Decimal @db.Decimal(10, 2)
  subtotal       Decimal @db.Decimal(10, 2)
  exclusiones    String[]
  observacion    String?

  pedido   Pedido   @relation(fields: [pedidoId], references: [id])
  producto Producto @relation(fields: [productoId], references: [id])

  @@map("detalle_pedidos")
}

// ==========================================
// CAJA
// ==========================================

enum EstadoCaja {
  ABIERTA
  CERRADA
}

model Caja {
  id           Int        @id @default(autoincrement())
  sucursalId   Int
  usuarioId    Int
  estado       EstadoCaja @default(ABIERTA)
  montoInicial Decimal    @db.Decimal(10, 2)
  montoFinal   Decimal?   @db.Decimal(10, 2)
  diferencia   Decimal?   @db.Decimal(10, 2)
  abiertaEn    DateTime   @default(now())
  cerradaEn    DateTime?

  sucursal Sucursal     @relation(fields: [sucursalId], references: [id])
  usuario  Usuario      @relation(fields: [usuarioId], references: [id])
  pedidos  Pedido[]
  eventos  EventoCaja[]

  @@map("cajas")
}

// ==========================================
// EVENTOS DE CAJA
// ==========================================

enum TipoEventoCaja {
  APERTURA
  CIERRE
  APERTURA_IRREGULAR
  DIFERENCIA
  MOVIMIENTO
}

model EventoCaja {
  id          Int            @id @default(autoincrement())
  cajaId      Int
  usuarioId   Int
  tipo        TipoEventoCaja
  descripcion String
  esAlerta    Boolean        @default(false)
  creadoEn    DateTime       @default(now())

  caja    Caja    @relation(fields: [cajaId], references: [id])
  usuario Usuario @relation(fields: [usuarioId], references: [id])

  @@map("eventos_caja")
}

// ==========================================
// MÓDULO FINANCIERO
// ==========================================

enum TipoMovimiento {
  INGRESO
  EGRESO
}

enum CategoriaMovimiento {
  VENTA
  COMPRA_INSUMOS
  NOMINA
  SERVICIOS
  ARRIENDO
  MANTENIMIENTO
  IMPUESTOS
  OTROS
}

model MovimientoFinanciero {
  id          Int                 @id @default(autoincrement())
  empresaId   Int
  sucursalId  Int
  usuarioId   Int
  tipo        TipoMovimiento
  categoria   CategoriaMovimiento
  descripcion String
  monto       Decimal             @db.Decimal(10, 2)
  fecha       DateTime            @default(now())
  pedidoId    Int?
  comprobante String?
  creadoEn    DateTime            @default(now())

  empresa  Empresa  @relation(fields: [empresaId], references: [id])
  sucursal Sucursal @relation(fields: [sucursalId], references: [id])
  usuario  Usuario  @relation(fields: [usuarioId], references: [id])
  pedido   Pedido?  @relation(fields: [pedidoId], references: [id])

  @@map("movimientos_financieros")
}